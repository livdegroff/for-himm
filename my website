<button onclick="generateChallenge()">
  Give Me A Challenge
</button>
<p id="challenge"></p>
<script>
const challenges = [
  "Do 10 jumping jacks",
  "Send me a random selfie",
  "Drink a glass of water",
  "Touch grass for 30 seconds",
  "Tell me your favorite memory of us",
  "Listen to a random song and rate it",
  "Do your best dance move",
  "Find the weirdest object in your room",
  "Text me the 3rd photo in your camera roll",
  "Compliment yourself right now"
];
function generateChallenge() {
  const random =
    challenges[Math.floor(Math.random() * challenges.length)];
  document.getElementById("challenge").innerText = random;
}
</script> 

